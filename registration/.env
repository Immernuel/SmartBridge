# # Ethereum private key or 1Password reference (e.g. op://vault/item/field)
# CRE_ETH_PRIVATE_KEY=your-eth-private-key
# # Default target used when --target flag is not specified (e.g. staging-settings, production-settings, my-target)
# CRE_TARGET=staging-settings

# ============================================================
#  SmartBridge — Local Simulation Secrets
#  NEVER commit this file. It is already in .gitignore.
#  Docs: https://docs.chain.link/cre/guides/workflow/secrets/using-secrets-simulation
# ============================================================

# ── Wallet private key (64 hex chars, NO 0x prefix) ─────────────────────────
# Used by the simulator for EVM reads/writes on Sepolia.
# Must be funded with Sepolia ETH: https://faucets.chain.link/sepolia
CRE_ETH_PRIVATE_KEY=756c19d692481d3fabdec27732af9b0bdf4d0acf15a452d2f245882f8f0a5e18

# ── Registry backend auth token ──────────────────────────────────────────────
# The bearer token your backend uses to authenticate incoming CRE requests.
# The env var name must match the entry under secrets.yaml → REGISTRY_TOKEN
REGISTRY_TOKEN_ALL=47GFF71hzZsmQDIchNon4mIY6OqKnfK74FMkfqvRHYE

# # Default target used when --target flag is not specified (e.g. staging-settings, production-settings, my-target)
CRE_TARGET=staging-settings

# ── CRE API key (optional — alternative to `cre login` for CI) ───────────────
# CRE_API_KEY=your-cre-api-key-here
